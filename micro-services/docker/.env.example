# Docker Compose Environment Variables
# Copy this file to .env and fill in your MongoDB URIs

MONGO_URI_DOCTOR=mongodb+srv://<user>:<password>@cluster.mongodb.net/doctor-db?retryWrites=true&w=majority
MONGO_URI_APPOINTMENT=mongodb+srv://<user>:<password>@cluster.mongodb.net/appointment-db?retryWrites=true&w=majority
MONGO_URI_PAYMENT=mongodb+srv://<user>:<password>@cluster.mongodb.net/payment-db?retryWrites=true&w=majority
MONGO_URI_PRESCRIPTION=mongodb+srv://<user>:<password>@cluster.mongodb.net/prescription-db?retryWrites=true&w=majority
